# EditorConfig is awesome: https://EditorConfig.org
# This file enforces consistent coding style across editors and IDEs.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.rs]
indent_size = 4

[*.toml]
indent_size = 4

[Makefile]
indent_style = tab
